# Halo ITSM MCP server — environment contract.
# Copy to `.env` (git-ignored) and fill in. NEVER commit a populated .env.
# See README.md for the Halo API application registration runbook.

# --- Required ---------------------------------------------------------------

# Resource Server API base, e.g. https://<instance>.haloitsm.com/api
HALO_API_URL=

# Full OAuth token endpoint. The exact form varies by instance (see README):
#   https://<Authorisation Server>/token        (set HALO_TENANT for ?tenant=)
#   https://<Resource Server>/auth/token
HALO_AUTH_URL=

# From the registered API application (Authentication Method = "Client ID and Secret (Services)").
HALO_CLIENT_ID=
HALO_CLIENT_SECRET=

# --- Optional ---------------------------------------------------------------

# Tenant name. Only needed when HALO_AUTH_URL uses the ?tenant= convention.
# HALO_TENANT=

# Space-separated OAuth scopes. Default is a least-privilege read set.
# Widen this (e.g. add "edit:tickets") ONLY when enabling writes, and grant the
# matching permissions on the Halo application too.
# HALO_SCOPES=read:tickets read:assets read:customers read:users read:agents

# Register write tools. Defaults to false. Must be exactly "true" to enable.
# HALO_ENABLE_WRITES=false

# Default page size for list calls (1..1000).
# HALO_PAGE_SIZE=50

# httpx request timeout in seconds.
# HALO_TIMEOUT=30
